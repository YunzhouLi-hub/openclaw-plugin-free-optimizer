# =====================================================
# Free Optimizer — API Keys 配置
# =====================================================
# API Key 通过环境变量传入（优先级高于 config.json）
# 你只需要配置你需要用的平台，不需要全部填
#
# 用法（bash/zsh）：
#   export $(cat .env | xargs)
#
# OpenClaw 用户推荐在 ~/.openclaw/env 里设置
#
# 去哪里取得 Key：
#   OpenRouter   → https://openrouter.ai/keys
#   Google Gemini → https://aistudio.google.com/apikey
#   Groq         → https://console.groq.com/keys
#   Cerebras     → https://cloud.cerebras.ai/
#   Mistral      → https://console.mistral.ai/api-keys/
#   NVIDIA NIM   → https://build.nvidia.com/
#   Cloudflare   → https://dash.cloudflare.com/profile/api-tokens
#   GitHub Models→ https://github.com/settings/tokens
# =====================================================

# OpenRouter（推荐，模型最全）
export FREE_OPT_OPENROUTER_KEY=""

# Google Gemini / Gemma（免费额度大）
export FREE_OPT_GOOGLE_KEY=""

# Groq（速度最快，200ms 内）
export FREE_OPT_GROQ_KEY=""

# Cerebras（最快的推理芯片）
export FREE_OPT_CEREBRAS_KEY=""

# Mistral（法语 / 编码强）
export FREE_OPT_MISTRAL_KEY=""

# NVIDIA NIM（推理模型丰富）
export FREE_OPT_NVIDIA_KEY=""

# Cloudflare Workers AI（延迟低，但模型小）
export FREE_OPT_CLOUDFLARE_KEY=""
# Cloudflare 需要额外填 Account ID（在 Cloudflare Dashboard 首页右上角）
export CLOUDFLARE_ACCOUNT_ID=""

# GitHub Models（GPT-4o 等微软系免费）
export FREE_OPT_GITHUB_KEY=""

# HuggingFace Inference（开源模型多）
export FREE_OPT_HUGGINGFACE_KEY=""
